# AntiGravity Park - Environment Variables Template
# Copy these keys into your Render.com Environment Variables dashboard

# Core
MONGO_URI=mongodb+srv://...
MONGO_DB=parkeasy
JWT_SECRET_KEY=yoursecret
SECRET_KEY=yoursecret
DEBUG=False

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER="ParkEasy Support <your-email@gmail.com>"
